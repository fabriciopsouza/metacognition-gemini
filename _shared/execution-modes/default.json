{
  "_mode": "default",
  "_description": "Modo conservador. Prompts para a maioria das ações de shell. Allow restrito a Read/Edit/Write. Ask para git push/merge/pr. Deny destrutivo robusto.",
  "_applies_to": "permissions.allow + permissions.ask + permissions.deny + permissions.defaultMode em ~/.claude/settings.json",
  "permissions": {
    "defaultMode": "default",
    "allow": [
      "Read",
      "Edit",
      "Write"
    ],
    "ask": [
      "Bash(git push:*)",
      "Bash(git merge:*)",
      "Bash(gh pr merge:*)",
      "Bash(gh pr create:*)"
    ],
    "deny": [
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git push --force-with-lease:*)",
      "Bash(rm -rf:*)",
      "Bash(rm -fr:*)",
      "Bash(rm -rfv:*)",
      "Bash(rm -rfd:*)",
      "Bash(rm --recursive:*)",
      "Bash(rm --force:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -fd:*)",
      "Bash(git clean -fdx:*)",
      "Bash(git branch -D:*)",
      "PowerShell(Remove-Item:*)",
      "PowerShell(rm:*)",
      "PowerShell(rmdir:*)",
      "PowerShell(del:*)",
      "PowerShell(erase:*)",
      "PowerShell(ri:*)",
      "PowerShell(Clear-Content:*)"
    ]
  }
}
